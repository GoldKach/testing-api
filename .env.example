# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT VARIABLE REFERENCE — testing-api
# This file is committed to git as documentation.
# Copy to .env.local for local development; supply real values via your
# deployment system (PM2 ecosystem, Docker, etc.) for production.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=8000

# PostgreSQL connection string
# Local:      postgresql://goldkach_dev:PASSWORD@localhost:5432/goldkach_dev
# Production: Use a pooled Neon URL with ?sslmode=require&channel_binding=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Direct (non-pooled) connection — required for Prisma interactive transactions.
# For local PostgreSQL this is the same as DATABASE_URL.
# For Neon: use the non-pooler endpoint URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# JWT signing secrets — generate with: openssl rand -base64 32
JWT_SECRET="replace-with-strong-random-secret"
ACCESS_TOKEN_SECRET="replace-with-strong-random-secret"
REFRESH_TOKEN_SECRET="replace-with-strong-random-secret"

# Frontend URL — used in auth email links and redirects
APP_URL="https://yourdomain.com"

# Resend transactional email — https://resend.com
# Leave empty locally to disable email sending.
RESEND_API_KEY="re_..."
MAIL_FROM="Your App <noreply@yourdomain.com>"
MAIL_REPLY_TO=""

# Google reCAPTCHA v3 backend secret — https://www.google.com/recaptcha/admin
# Local always-pass test key: 6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ45Ik_kD
RECAPTCHA_SECRET_KEY="your-recaptcha-v3-secret-key"

# Portfolio report cron schedule
# Options: daily | 30-minute | 10-minute | 5-minute | 2-minute | 1-minute | 30-second
# Leave empty to disable automatic scheduling.
CRON_MODE=""

# Shown in audit log entries
SYSTEM_VERSION="1.0.0"
