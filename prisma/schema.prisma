
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =====================
// Enums
// =====================

enum UserRole {
  SUPER_ADMIN
  MANAGER
  ADMIN
  USER
  AGENT
  CLIENT_RELATIONS
  ACCOUNT_MANAGER
  STAFF
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
  DEACTIVATED
  BANNED
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  CLOSED
  FROZEN
}

enum TransactionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AssetClass {
  EQUITIES
  ETFS
  REITS
  BONDS
  CASH
  OTHERS
}

enum ReportPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

enum TopupStatus {
  PENDING // top-up deposit received, sub-portfolio created (X1)
  MERGED // recalculation done, X2 generated, X1 absorbed
}

enum WalletType {
  MASTER // the one general wallet that aggregates all portfolios
  PORTFOLIO // one wallet per UserPortfolio
}

enum DepositTarget {
  MASTER     // external money deposited into master wallet (cash available)
  ALLOCATION // internal transfer: master wallet → portfolio wallet (triggers top-up)
}

enum WithdrawalType {
  HARD_WITHDRAWAL // cash out from master wallet to client's bank
  REDEMPTION      // internal transfer: portfolio wallet → master wallet
}

// =====================
// Core Auth Models
// =====================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String     @id @default(cuid())
  name          String
  firstName     String
  lastName      String?
  phone         String     @unique
  email         String     @unique
  emailVerified Boolean    @default(false)
  password      String
  imageUrl      String     @default("https://ylhpxhcgr4.ufs.sh/f/ZVlDsNdibGfFLkXm6f8jxEOgRvuoCGdTw7N05shB2kHlF1LU?expires=1760298626027&signature=hmac-sha256%3De5e64a05048cc6fd92c9ca7aabf68cf8a9992143d9f2bce18cfd5e7e30d6e5d4")
  role          UserRole   @default(USER)
  status        UserStatus @default(PENDING)
  isApproved    Boolean    @default(false)
  token         String?
  roleId        String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts         Account[]
  sessions         Session[]
  resetTokens      PasswordResetToken[]
  refreshTokens    RefreshToken[]
  individualOnboarding IndividualOnboarding?
  companyOnboarding    CompanyOnboarding?

  // One master wallet per user (aggregates across all portfolio wallets)
  masterWallet MasterWallet?

  // Deposits/withdrawals where this user is the CLIENT (the account being funded/debited)
  deposits    Deposit[]    @relation("ClientDeposits")
  withdrawals Withdrawal[] @relation("ClientWithdrawals")

  // Deposits/withdrawals this staff member CREATED on behalf of a client
  createdDeposits    Deposit[]    @relation("DepositCreatedBy")
  createdWithdrawals Withdrawal[] @relation("WithdrawalCreatedBy")

  // Deposits/withdrawals this staff member APPROVED
  approvedDeposits    Deposit[]    @relation("DepositApprovedBy")
  approvedWithdrawals Withdrawal[] @relation("WithdrawalApprovedBy")

  // Deposits/withdrawals this staff member REJECTED
  rejectedDeposits    Deposit[]    @relation("DepositRejectedBy")
  rejectedWithdrawals Withdrawal[] @relation("WithdrawalRejectedBy")

  portfolioSummary PortfolioSummary[]

  // A user can hold many named portfolio enrollments
  userPortfolios UserPortfolio[]

  activityLogs    ActivityLog[]
  agentAssignment AgentClientAssignment? @relation("ClientAssignment")
  staffProfile    StaffProfile?
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// =====================
// Staff
// =====================

model StaffProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  employeeId  String?  @unique
  department  String?
  position    String?
  bio         String?
  isActive    Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignedClients   AgentClientAssignment[]
  companyOnboardingClients    CompanyOnboarding[]    @relation("CompanyOnboardingAgent")
  individualOnboardingClients IndividualOnboarding[] @relation("IndividualOnboardingAgent")

}

model AgentClientAssignment {
  id           String       @id @default(cuid())
  agentId      String
  agent        StaffProfile @relation(fields: [agentId], references: [id], onDelete: Cascade)
  clientId     String       @unique
  client       User         @relation("ClientAssignment", fields: [clientId], references: [id], onDelete: Cascade)
  assignedById String?
  assignedAt   DateTime     @default(now())
  isActive     Boolean      @default(true)
  unassignedAt DateTime?

  @@index([agentId])
  @@index([clientId])
}

