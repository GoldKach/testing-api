// =====================
// Wallets
// =====================

// One master wallet per user — aggregates balance across all portfolio wallets
model MasterWallet {
  id            String @id @default(cuid())
  accountNumber String @unique
  userId        String @unique
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Cash sitting in master wallet — available for withdrawal or allocation to a portfolio
  balance        Float @default(0.0)

  // Rolling totals across all portfolio wallets
  totalDeposited Float @default(0.0) // sum of all approved external deposits
  totalWithdrawn Float @default(0.0) // sum of all approved hard withdrawals
  totalFees      Float @default(0.0) // sum of all fees across portfolios
  netAssetValue  Float @default(0.0) // sum of NAV across all portfolio wallets

  // Maintenance and management fees
  maintenanceFee Float @default(2.0) // $2 per client per period
  managementFee Float @default(0.0) // calculated based on NAV (0.5% quarterly, 2% annually)

  // Last fee deduction tracking
  lastMaintenanceFeeDate DateTime?
  lastManagementFeeDate  DateTime?

  status    AccountStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  deposits    Deposit[]
  withdrawals Withdrawal[]
}

// One PortfolioWallet per UserPortfolio
model PortfolioWallet {
  id              String        @id @default(cuid())
  accountNumber   String        @unique
  userPortfolioId String        @unique
  userPortfolio   UserPortfolio @relation(fields: [userPortfolioId], references: [id], onDelete: Cascade)

  balance        Float @default(0.0) // cash balance in this portfolio wallet
  bankFee        Float @default(0.0) // fees now deducted from master wallet
  transactionFee Float @default(0.0) // fees now deducted from master wallet
  feeAtBank      Float @default(0.0) // fees now deducted from master wallet
  totalFees      Float @default(0.0) // fees now deducted from master wallet
  netAssetValue  Float @default(0.0) // total close value of assets + cash balance

  status    AccountStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  deposits    Deposit[]
  withdrawals Withdrawal[]
}

// =====================
// Deposits & Withdrawals
// =====================

model Deposit {
  id String @id @default(cuid())

  // The CLIENT whose portfolio is being funded
  userId String
  user   User   @relation("ClientDeposits", fields: [userId], references: [id], onDelete: Cascade)

  // Staff who CREATED this deposit request (admin/agent — NOT the client)
  createdById   String?
  createdBy     User?     @relation("DepositCreatedBy", fields: [createdById], references: [id])
  createdByName String?
  createdByRole UserRole?

  // Staff who APPROVED this deposit
  approvedById   String?
  approvedBy     User?     @relation("DepositApprovedBy", fields: [approvedById], references: [id])
  approvedByName String?
  approvedAt     DateTime?

  // Staff who REJECTED this deposit
  rejectedById   String?
  rejectedBy     User?     @relation("DepositRejectedBy", fields: [rejectedById], references: [id])
  rejectedByName String?
  rejectedAt     DateTime?
  rejectReason   String?

  // One of these is set depending on depositTarget
  masterWalletId    String?
  masterWallet      MasterWallet?    @relation(fields: [masterWalletId], references: [id])
  portfolioWalletId String?
  portfolioWallet   PortfolioWallet? @relation(fields: [portfolioWalletId], references: [id])

  // Which portfolio this deposit is going into (null if depositing to master only)
  userPortfolioId String?
  userPortfolio   UserPortfolio? @relation(fields: [userPortfolioId], references: [id])

  depositTarget     DepositTarget     @default(MASTER)
  amount            Float
  transactionId     String?           @unique
  transactionStatus TransactionStatus @default(PENDING)
  mobileNo          String?
  referenceNo       String?
  accountNo         String?
  method            String?
  description       String?
  proofUrl          String?
  proofFileName     String?

  // One-time fees deducted on the FIRST deposit to master wallet
  bankCost        Float @default(0.0)  // e.g. $30 bank processing fee
  transactionCost Float @default(0.0)  // e.g. $10 transaction fee
  cashAtBank      Float @default(0.0)  // e.g. $10 cash held at bank
  totalFees       Float @default(0.0)  // bankCost + transactionCost + cashAtBank
  isFirstDeposit  Boolean @default(false) // true if this is the client's first MASTER deposit

  // If this deposit triggered a top-up, link to the TopupEvent
  topupEvent TopupEvent?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdById])
  @@index([userPortfolioId])
}

model Withdrawal {
  id String @id @default(cuid())

  // The CLIENT whose portfolio is being debited
  userId String
  user   User   @relation("ClientWithdrawals", fields: [userId], references: [id], onDelete: Cascade)

  // Staff who CREATED this withdrawal request (admin/agent — NOT the client)
  createdById   String?
  createdBy     User?     @relation("WithdrawalCreatedBy", fields: [createdById], references: [id])
  createdByName String?
  createdByRole UserRole?

  // Staff who APPROVED this withdrawal
  approvedById   String?
  approvedBy     User?     @relation("WithdrawalApprovedBy", fields: [approvedById], references: [id])
  approvedByName String?
  approvedAt     DateTime?

  // Staff who REJECTED this withdrawal
  rejectedById   String?
  rejectedBy     User?     @relation("WithdrawalRejectedBy", fields: [rejectedById], references: [id])
  rejectedByName String?
  rejectedAt     DateTime?
  rejectReason   String?

  masterWalletId    String?
  masterWallet      MasterWallet?    @relation(fields: [masterWalletId], references: [id])
  portfolioWalletId String?
  portfolioWallet   PortfolioWallet? @relation(fields: [portfolioWalletId], references: [id])

  // Withdrawal is always from a specific portfolio
  userPortfolioId String?
  userPortfolio   UserPortfolio? @relation(fields: [userPortfolioId], references: [id])

  withdrawalType    WithdrawalType    @default(HARD_WITHDRAWAL)
  amount            Float
  transactionStatus TransactionStatus @default(PENDING)
  accountNo         String?
  accountName       String?
  referenceNo       String
  transactionId     String?           @unique
  method            String?
  bankName          String            @default("")
  bankAccountName   String            @default("")
  bankBranch        String            @default("")
  description       String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([userId])
  @@index([createdById])
  @@index([userPortfolioId])
}

// =====================
// Assets & Portfolios (Template layer)
// =====================

model Asset {
  id                          String     @id @default(cuid())
  symbol                      String     @unique
  description                 String
  sector                      String
  assetClass                  AssetClass @default(OTHERS)
  defaultAllocationPercentage Float      @default(0.0)
  defaultCostPerShare         Float      @default(0.0)
  closePrice                  Float      @default(0.0)
  portfolioAssets     PortfolioAsset[]
  userPortfolioAssets UserPortfolioAsset[]
  subPortfolioAssets  SubPortfolioAsset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Portfolio {
  id                   String           @id @default(cuid())
  name                 String           @unique
  description          String?
  timeHorizon          String
  riskTolerance        String
  allocationPercentage Float            @default(100)
  assets               PortfolioAsset[]
  userPortfolios       UserPortfolio[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

model PortfolioAsset {
  id                          String @id @default(cuid())
  portfolioId                 String
  assetId                     String
  defaultAllocationPercentage Float  @default(0.0)
  defaultCostPerShare         Float  @default(0.0)
  lossGain                    Float  @default(0.0)
  closeValue                  Float  @default(0.0)
  costPrice                   Float  @default(0.0)
  stock                       Float  @default(0.0)

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  asset     Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([portfolioId, assetId])
}

// =====================
// User Portfolio (Named Enrollment)
// =====================

// A user can enroll into the same Portfolio template multiple times,
// each time giving it a custom name (e.g. "Retirement Fund", "School Fees").
// Each UserPortfolio is independent: its own wallet, sub-portfolios, and performance history.
model UserPortfolio {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  // Custom name given by the user (e.g. "Retirement Fund")
  customName String

  // Merged/live asset positions (the "active" X2 state after all top-ups merged)
  portfolioValue Float @default(0.0) // total close value of all merged assets
  totalInvested  Float @default(0.0) // total cost price across all sub-portfolios
  totalLossGain  Float @default(0.0) // totalCloseValue - totalInvested

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One dedicated wallet
  wallet PortfolioWallet?

  // The live merged asset holdings (X2 state)
  userAssets UserPortfolioAsset[]

  // All sub-portfolios: initial (X) + top-ups (X1, X2-source, …)
  subPortfolios SubPortfolio[]

  // Top-up events tracking each recalculation cycle
  topupEvents TopupEvent[]

  // Deposits/withdrawals referencing this portfolio
  deposits    Deposit[]
  withdrawals Withdrawal[]

  // Performance reports
  performanceReports UserPortfolioPerformanceReport[]

  @@unique([userId, portfolioId, customName])
  @@index([userId])
}

// The live merged asset positions for a UserPortfolio (the "X2" state)
model UserPortfolioAsset {
  id              String @id @default(cuid())
  userPortfolioId String
  assetId         String

  allocationPercentage Float @default(0.0)
  costPerShare         Float @default(0.0) // weighted average cost per share
  costPrice            Float @default(0.0) // total cost price (sum across sub-portfolios)
  stock                Float @default(0.0) // total shares (sum across sub-portfolios)
  closeValue           Float @default(0.0) // stock * current close price
  lossGain             Float @default(0.0) // closeValue - costPrice

  userPortfolio UserPortfolio @relation(fields: [userPortfolioId], references: [id], onDelete: Cascade)
  asset         Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userPortfolioId, assetId])
}

// =====================
// Sub-Portfolios (X, X1, X2-source snapshots)
// =====================

// Every time money is invested into a UserPortfolio, a SubPortfolio is created.
// - generation = 0  → the original portfolio (X)
// - generation = 1  → first top-up slice (X1)
// - generation = 2  → second top-up slice (X2-source), etc.
// After a top-up is merged, the UserPortfolioAssets are recalculated and a
// new TopupEvent record marks the merge as complete.
// SubPortfolios are kept for audit/report history and are never deleted.
model SubPortfolio {
  id              String        @id @default(cuid())
  userPortfolioId String
  userPortfolio   UserPortfolio @relation(fields: [userPortfolioId], references: [id], onDelete: Cascade)

  // 0 = original, 1 = first top-up, 2 = second top-up, …
  generation Int @default(0)

  // Label auto-generated: "{customName} - Gen {generation}" or override
  label String

  amountInvested  Float @default(0.0) // deposit amount for this slice
  totalCostPrice  Float @default(0.0) // sum of cost prices for assets in this slice
  totalCloseValue Float @default(0.0) // sum of close values for assets in this slice
  totalLossGain   Float @default(0.0)

  bankFee        Float @default(30)
  transactionFee Float @default(10)
  feeAtBank      Float @default(10)
  totalFees      Float @default(50)
  cashAtBank     Float @default(0.0)

  // Snapshot date (when assets were bought / top-up was applied)
  snapshotDate DateTime @default(now())

  assets SubPortfolioAsset[]

  // Link to the TopupEvent that merged this sub-portfolio (null if not yet merged or is generation 0 initial)
  mergedByTopup   TopupEvent? @relation("MergedSubPortfolios", fields: [topupEventId], references: [id])
  mergedByTopupId String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  topupEventId String?

  @@index([userPortfolioId, generation])
}

// Asset positions within a SubPortfolio snapshot
model SubPortfolioAsset {
  id             String       @id @default(cuid())
  subPortfolioId String
  subPortfolio   SubPortfolio @relation(fields: [subPortfolioId], references: [id], onDelete: Cascade)
  assetId        String
  asset          Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)

  allocationPercentage Float @default(0.0)
  costPerShare         Float @default(0.0)
  costPrice            Float @default(0.0)
  stock                Float @default(0.0)
  closePrice           Float @default(0.0)
  closeValue           Float @default(0.0)
  lossGain             Float @default(0.0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([subPortfolioId, assetId])
}

// =====================
// Top-up Events (Recalculation Audit Trail)
// =====================

// Whenever a user tops up a portfolio, a TopupEvent is created.
// It records:
//   - the deposit that triggered it
//   - which sub-portfolios (X and X1) were merged
//   - the resulting recalculated totals (the "X2" state)
model TopupEvent {
  id              String        @id @default(cuid())
  userPortfolioId String
  userPortfolio   UserPortfolio @relation(fields: [userPortfolioId], references: [id], onDelete: Cascade)

  // The deposit that funded this top-up
  depositId String  @unique
  deposit   Deposit @relation(fields: [depositId], references: [id], onDelete: Cascade)

  topupAmount   Float // the new money added (X1 amount)
  previousTotal Float // total invested before top-up (X total)

  // Post-merge totals (X2 = X + X1)
  newTotalInvested   Float @default(0.0)
  newTotalCloseValue Float @default(0.0)
  newTotalLossGain   Float @default(0.0)
  newTotalFees       Float @default(0.0)
  newNetAssetValue   Float @default(0.0)

  status   TopupStatus @default(PENDING)
  mergedAt DateTime?

  // All sub-portfolios that were merged in this event
  mergedSubPortfolios SubPortfolio[] @relation("MergedSubPortfolios")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userPortfolioId])
}

// =====================
// Portfolio Summary (per user, aggregated)
// =====================

model PortfolioSummary {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  // Aggregated across ALL of the user's portfolio wallets
  cashAtBank      Float @default(0.0)
  cashOutstanding Float @default(0.0)
  cashAvailable   Float @default(0.0)
  totalInvested   Float @default(0.0)
  totalCloseValue Float @default(0.0)
  totalLossGain   Float @default(0.0)
  netAssetValue   Float @default(0.0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================
// Activity Logging
// =====================

model ActivityLog {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action          String
  module          String?
  status          String?
  description     String?
  method          String?
  platform        String?
  performedByRole String?
  entityId        String?
  entityType      String?
  referrerUrl     String?
  ipAddress       String?
  userAgent       String?
  location        String?
  isAutomated     Boolean? @default(false)
  durationMs      Int?
  errorMessage    String?
  metadata        Json?
  createdAt       DateTime @default(now())

  @@index([userId, action, createdAt])
}

// =====================
// Performance Reports
// =====================

model UserPortfolioPerformanceReport {
  id              String        @id @default(cuid())
  userPortfolioId String
  userPortfolio   UserPortfolio @relation(fields: [userPortfolioId], references: [id], onDelete: Cascade)

  reportDate DateTime     @default(now())
  period     ReportPeriod @default(DAILY)

  // Aggregated merged (X2) totals
  totalCostPrice  Float @default(0)
  totalCloseValue Float @default(0)
  totalLossGain   Float @default(0)
  totalPercentage Float @default(0)
  totalFees       Float @default(0)
  netAssetValue   Float @default(0)

  assetBreakdown PortfolioAssetBreakdown[]

  // Sub-portfolio breakdown for full drill-down in reports
  subPortfolioSnapshots SubPortfolioReportSnapshot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([userPortfolioId, reportDate])
  @@index([reportDate])
  @@index([userPortfolioId, period, reportDate])
}

model PortfolioAssetBreakdown {
  id             String     @id @default(cuid())
  reportId       String
  assetClass     AssetClass
  holdings       Int        @default(0)
  totalCashValue Float      @default(0)
  percentage     Float      @default(0)

  report    UserPortfolioPerformanceReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  createdAt DateTime                       @default(now())

  @@unique([reportId, assetClass])
  @@index([reportId])
}

// Snapshot of each sub-portfolio at the time a performance report is generated.
// This allows a report to show: "Portfolio X contributed $X, Top-up 1 contributed $Y, merged total $Z"
model SubPortfolioReportSnapshot {
  id       String                         @id @default(cuid())
  reportId String
  report   UserPortfolioPerformanceReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  subPortfolioId String
  generation     Int
  label          String

  amountInvested  Float @default(0.0)
  totalCostPrice  Float @default(0.0)
  totalCloseValue Float @default(0.0)
  totalLossGain   Float @default(0.0)
  totalFees       Float @default(0.0)
  cashAtBank      Float @default(0.0)

  createdAt DateTime @default(now())

  @@index([reportId])
}



enum CompanyType {
  LIMITED
  PARTNERSHIP
  NGO
  COOPERATIVE
  SAVINGS_GROUP
  MICROFINANCE
}

enum OwnershipType {
  OWNERSHIP_BY_SENIOR
  MANAGEMENT_OFFICIAL
  OTHER
}

enum BeneficiaryRelation {
  SPOUSE
  CHILD
  PARENT
  SIBLING
  OTHER
}

// =====================
// Individual Onboarding
// =====================

model IndividualOnboarding {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  // Agent selected during onboarding
  agentId String?
  agent   StaffProfile? @relation("IndividualOnboardingAgent", fields: [agentId], references: [id], onUpdate: Cascade)

  // Personal info
  fullName         String?
  dateOfBirth      DateTime?
  tin              String?   @unique  // Optional for individuals
  avatarUrl        String?
  homeAddress      String?
  email            String?
  phoneNumber      String?
  employmentStatus String?
  occupation       String?
  companyName      String?   // employer name (optional)
  hasBusiness      String?

  // Investment profile
  primaryGoal          String?
  timeHorizon          String?
  riskTolerance        String?
  investmentExperience String?
  sourceOfIncome       String?   // renamed from sourceOfWealth
  employmentIncome     String?
  expectedInvestment   String?
  businessOwnership    String?

  // PEP
  isPEP                   String?
  publicPosition          String?
  relationshipToCountry   String?
  familyMemberDetails     String?

  // Legal/compliance
  sanctionsOrLegal        String?
  consentToDataCollection Boolean?
  agreeToTerms            Boolean?

  // Documents
  nationalIdUrl     String?   // National ID or Passport (required)
  passportPhotoUrl  String?
  tinCertificateUrl String?
  bankStatementUrl  String?   // Optional for individuals

  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  beneficiaries Beneficiary[]
  nextOfKin     NextOfKin[]
}

// =====================
// Beneficiary (for Individual Onboarding)
// =====================

model Beneficiary {
  id                     String               @id @default(cuid())
  individualOnboardingId String
  individualOnboarding   IndividualOnboarding @relation(fields: [individualOnboardingId], references: [id], onDelete: Cascade)

  fullName    String
  dateOfBirth DateTime?
  phone       String
  address     String?
  relation    BeneficiaryRelation @default(OTHER)
  tin         String?             // Optional

  // Document upload
  documentUrl String? // National ID or Passport scan

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([individualOnboardingId])
}

// =====================
// Next of Kin (for Individual Onboarding)
// =====================

model NextOfKin {
  id                     String               @id @default(cuid())
  individualOnboardingId String
  individualOnboarding   IndividualOnboarding @relation(fields: [individualOnboardingId], references: [id], onDelete: Cascade)

  fullName    String
  dateOfBirth DateTime?
  phone       String
  address     String?
  relation    BeneficiaryRelation @default(OTHER)
  tin         String?             // Optional

  // Document upload
  documentUrl String? // National ID or Passport scan

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([individualOnboardingId])
}

// =====================
// Company Onboarding
// =====================

model CompanyOnboarding {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  // Agent selected during onboarding
  agentId String?
  agent   StaffProfile? @relation("CompanyOnboardingAgent", fields: [agentId], references: [id], onUpdate: Cascade)

  // Company details
  companyName  String
  email        String
  logoUrl      String?
  companyType  CompanyType
  phoneNumbers String[] // Array of official phone numbers

  // Company registration
  registrationNumber  String?   @unique
  tin                 String?   @unique
  incorporationDate   DateTime?
  companyAddress      String?
  businessType        String?   // additional description if needed

  // Investment profile
  primaryGoal          String?
  timeHorizon          String?
  riskTolerance        String?
  investmentExperience String?
  sourceOfIncome       String?
  expectedInvestment   String?

  // PEP / Legal
  isPEP                   String?
  sanctionsOrLegal        String?
  consentToDataCollection Boolean?
  agreeToTerms            Boolean?

  // Company documents
  constitutionUrl              String?  // Required for SACCOs
  tradingLicenseUrl            String?
  bankStatementUrl             String?  // Required
  tinCertificateUrl            String?
  logoDocUrl                   String?
  formA1Url                    String?
  formS18Url                   String?
  form18Url                    String?
  form20Url                    String?
  beneficialOwnershipFormUrl   String?
  memorandumArticlesUrl        String?
  officialAccountUrl           String?

  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  directors CompanyDirector[]
  ubos      CompanyUBO[]
}

// =====================
// Company Director
// =====================

model CompanyDirector {
  id                  String            @id @default(cuid())
  companyOnboardingId String
  companyOnboarding   CompanyOnboarding @relation(fields: [companyOnboardingId], references: [id], onDelete: Cascade)

  fullName    String
  email       String?
  phone       String?
  address     String?
  dateOfBirth DateTime?
  ninOrPassportNumber String?

  // Document upload (National ID or Passport)
  documentUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyOnboardingId])
}

// =====================
// Company UBO (Ultimate Beneficial Owner)
// =====================

model CompanyUBO {
  id                  String            @id @default(cuid())
  companyOnboardingId String
  companyOnboarding   CompanyOnboarding @relation(fields: [companyOnboardingId], references: [id], onDelete: Cascade)

  fullName    String
  email       String?
  phone       String?
  address     String?
  dateOfBirth DateTime?
  ninOrPassportNumber String?

  ownershipType      OwnershipType @default(OTHER)
  ownershipTypeOther String?       // Explanation if ownershipType = OTHER

  // Document upload (National ID or Passport)
  documentUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyOnboardingId])
}

